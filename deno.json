{
  "nodeModulesDir": "none",
  "tasks": {
    "run": "deno run --allow-net --allow-read --allow-write --allow-env main.ts",
    "build": "deno task compile --output out/toggl",
    "compile": "DENO_NO_PACKAGE_JSON=1 deno run --allow-read --allow-write --allow-run=deno scripts/compile.ts",
    "dist": "DENO_NO_PACKAGE_JSON=1 deno run --allow-read --allow-write --allow-run scripts/build_release.ts",
    "migrate-config": "deno run --allow-read --allow-write --allow-env scripts/migrate_config.ts",
    "install": "deno run --allow-read --allow-write --allow-run=deno --allow-env=HOME scripts/install.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@1.0.30",
    "@std/path": "jsr:@std/path@1",
    "@std/toml": "jsr:@std/toml@1",
    "ptera": "./ptera.ts"
  }
}
